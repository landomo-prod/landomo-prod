# ML Pricing Service - Environment Configuration Template

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3500
HOST=0.0.0.0
NODE_ENV=development

# ============================================
# DATABASE (Read-Only Multi-Country Access)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_READ_USER=ml_pricing_readonly
DB_READ_PASSWORD=ml_pricing_readonly_pass
DB_MAX_CONNECTIONS=10

# Supported country databases:
# landomo_czech, landomo_slovakia, landomo_hungary, landomo_austria, landomo_germany

# ============================================
# REDIS CACHE
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache TTL Configuration (seconds)
MODEL_CACHE_TTL=86400          # 24 hours
PREDICTION_CACHE_TTL=3600      # 1 hour

# ============================================
# API AUTHENTICATION
# ============================================
# Comma-separated API keys with optional version and expiry
# Format: key:v2:2026-12-31 or just key
API_KEYS=dev_ml_key_1,dev_ml_key_2:v2:2027-12-31

# ============================================
# ML MODEL CONFIGURATION
# ============================================
MODELS_DIR=/app/models
PYTHON_PATH=/app/ml-pricing-service/ml
ML_WORKER_CONCURRENCY=2

# Training Configuration
TRAINING_CRON=0 2 * * 0        # Every Sunday at 2 AM
MIN_TRAINING_SAMPLES=100       # Minimum samples required to train
TEST_SPLIT=0.2                 # 20% test set

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info                 # debug, info, warn, error
