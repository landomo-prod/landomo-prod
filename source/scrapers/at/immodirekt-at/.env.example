# Server Configuration
PORT=8088

# Scraping Behavior
HEADLESS=true
TIMEOUT=60000
MAX_RETRIES=3
RATE_LIMIT_DELAY=2000
MAX_PAGES_PER_CATEGORY=10

# Cloudflare Bypass
STEALTH_MODE=true
BYPASS_CLOUDFLARE=true

# Detail Enrichment
FETCH_DETAILS=true

# Ingest API
INGEST_API_URL=http://localhost:3004
INGEST_API_KEY_IMMODIREKT_AT=dev_key_austria_immodirekt
