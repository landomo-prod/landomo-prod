# Server Configuration
PORT=8086

# Ingest API Configuration
INGEST_API_URL=http://localhost:3004
INGEST_API_KEY_REALITY=dev_key_czech_reality

# Puppeteer / Browser Configuration
# Run browser in headless mode (true/false)
PUPPETEER_HEADLESS=true

# Browser timeout in milliseconds
BROWSER_TIMEOUT=30000

# Maximum concurrent pages (adjust based on available memory)
# Use 2-3 for stable operation, more may cause memory issues
MAX_CONCURRENT_PAGES=2

# Fetch details from listing detail pages (true/false)
FETCH_DETAILS=false

# Scraper Configuration
# Maximum pages to scrape per search context (default: 10000 = effectively unlimited)
# Scraper stops naturally after 3 consecutive empty pages
MAX_PAGES=10000
