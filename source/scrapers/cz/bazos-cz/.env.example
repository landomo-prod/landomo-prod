# Test Configuration
NODE_ENV=development
PORT=8082

# Azure AI Configuration - DeepSeek-V3.2 via AI Foundry API
AZURE_OPENAI_ENDPOINT=https://prg-operations.services.ai.azure.com/models/chat/completions
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=DeepSeek-V3.2
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# LLM Extraction Settings (DeepSeek-V3.2)
LLM_EXTRACTION_ENABLED=true
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_MS=30000

# Extraction Cache Settings (Legacy - in-memory)
EXTRACTION_CACHE_ENABLED=true
EXTRACTION_CACHE_TTL_DAYS=30

# Persistent Cache Settings (Redis + PostgreSQL Hybrid)
PERSISTENT_CACHE_ENABLED=false  # Set to true to enable hybrid cache (Redis L1 + PostgreSQL L2)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
EXTRACTION_CACHE_REDIS_TTL_SECONDS=604800  # 7 days (Redis L1 cache)

# PostgreSQL Cache Settings
DATABASE_URL=postgresql://landomo:landomo_dev_pass@localhost:5432/landomo_czech
# Or use individual connection params:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=landomo
# DB_PASSWORD=landomo_dev_pass
# DB_NAME=landomo_czech
EXTRACTION_CACHE_PG_ENABLED=true
EXTRACTION_CACHE_PG_TTL_DAYS=90  # 90 days (PostgreSQL L2 cache)

# Validation Settings
VALIDATION_ENABLED=false  # Set to true to enable property validation before ingestion

# Circuit Breaker Settings
CIRCUIT_BREAKER_ENABLED=false  # Set to true to enable circuit breaker (abort scrape on high failure rate)
CIRCUIT_BREAKER_THRESHOLD=0.30  # 30% failure rate threshold
CIRCUIT_BREAKER_MIN_SAMPLES=10  # Minimum samples before checking threshold

# Scraper Settings
MAX_PAGES=10000  # Maximum pages to scrape per section (default: unlimited until no more results)

# Ingest Service
INGEST_API_URL=http://ingest-czech:3003/api/v1/properties/bulk-ingest
INGEST_API_KEY=dev_key_cz_1
