# Server Configuration
PORT=8087

# Ingest API Configuration
INGEST_API_URL=http://localhost:3004
INGEST_API_KEY_IDNES_REALITY=dev_key_czech_1

# HTTP Configuration
HTTP_TIMEOUT=30000

# Scraping Configuration
RATE_LIMIT_DELAY=1000
FETCH_DETAILS=true

# Max pages per category (default: unlimited, set to 5 for testing)
# For 102,785 estates across 8 categories, expect ~1,000-2,000 pages per category
MAX_PAGES_PER_CATEGORY=999999
