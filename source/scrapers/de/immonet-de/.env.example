# Server Configuration
PORT=8088

# Ingest API Configuration
INGEST_API_URL=http://localhost:3004
INGEST_API_KEY_IMMONET_DE=dev_key_germany_immonet

# Playwright Configuration
HEADLESS=true
TIMEOUT=30000
