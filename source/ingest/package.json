{
  "name": "landomo-ingest",
  "version": "1.0.0",
  "description": "Landomo Ingest - Centralized REST API for property data ingestion",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/start-worker.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/start-worker.ts",
    "test": "jest",
    "test:setup": "tsx src/test-setup.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "landomo",
    "ingest",
    "data-ingestion",
    "api"
  ],
  "author": "Landomo",
  "license": "MIT",
  "dependencies": {
    "@landomo/core": "file:../shared",
    "@sentry/node": "^10.38.0",
    "axios": "^1.13.5",
    "bullmq": "^5.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "pg": "^8.11.3",
    "pino": "^9.0.0",
    "prom-client": "^15.1.0",
    "redis": "^4.6.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0"
  }
}
