# Server Configuration
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL (Read-Only User)
DB_HOST=localhost
DB_PORT=5432
DB_READ_USER=search_readonly
DB_READ_PASSWORD=secure_readonly_password
DB_MAX_CONNECTIONS=10

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Search Configuration
DEFAULT_SEARCH_LIMIT=20
MAX_SEARCH_LIMIT=100

# Cache TTL (seconds)
CACHE_TTL_SEARCH=300          # 5 minutes
CACHE_TTL_PROPERTY=1800       # 30 minutes
CACHE_TTL_AGGREGATIONS=3600   # 1 hour
CACHE_TTL_FILTERS=86400       # 24 hours

# Geo Search
DEFAULT_GEO_RADIUS_KM=10
MAX_GEO_RADIUS_KM=100
