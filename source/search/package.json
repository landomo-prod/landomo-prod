{
  "name": "landomo-search",
  "version": "1.0.0",
  "description": "Landomo Search Service - Federated search across all country databases",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:query": "jest query-builder",
    "test:search": "jest search-engine",
    "test:geo": "jest geo-search",
    "test:cache": "jest cache-strategies",
    "test:aggregator": "jest result-aggregator",
    "test:countries": "jest country-modules",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "landomo",
    "search",
    "federated-search",
    "api"
  ],
  "author": "Landomo",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.4.2",
    "@graphql-tools/schema": "^10.0.31",
    "@landomo/core": "file:../shared",
    "@pothos/core": "^4.3.0",
    "@sentry/node": "^10.38.0",
    "axios": "^1.13.5",
    "dataloader": "^2.2.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "fastify-plugin": "^5.0.1",
    "graphql": "^16.9.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-yoga": "^5.11.0",
    "pg": "^8.11.3",
    "pino": "^10.3.0",
    "prom-client": "^15.1.3",
    "redis": "^4.6.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0"
  }
}
