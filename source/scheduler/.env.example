# Scraper URLs (Docker network or localhost)
SREALITY_URL=http://sreality:8081/scrape
BEZREALITKY_URL=http://bezrealitky:8082/scrape

# Scraper Schedules (Cron expressions)
# Format: minute hour day month weekday
# Examples:
#   */5 * * * *  - Every 5 minutes
#   0 */2 * * *  - Every 2 hours at minute 0
#   30 4 * * *   - Daily at 4:30 AM

SREALITY_SCHEDULE=0 */2 * * *        # Every 2 hours
BEZREALITKY_SCHEDULE=30 */4 * * *    # Every 4 hours at :30

# Enable/disable individual scrapers
SREALITY_ENABLED=true
BEZREALITKY_ENABLED=true

# Optional: HTTP server for manual triggers
ENABLE_HTTP_TRIGGERS=true
SCHEDULER_PORT=9000
