# GoTrue (Supabase Auth) environment template
# Copy to secrets or .env and fill in real values before deploying

# --- JWT ---
GOTRUE_JWT_SECRET=${SUPABASE_JWT_SECRET}
GOTRUE_JWT_EXP=3600
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated

# --- Database ---
GOTRUE_DB_DRIVER=postgres
DATABASE_URL=postgres://${SUPABASE_DB_USER:-supabase_auth_admin}:${SUPABASE_DB_PASSWORD}@${DB_HOST:-cz-pgbouncer}:5432/${DB_NAME:-landomo_cz}?search_path=auth

# --- API ---
API_EXTERNAL_URL=${SUPABASE_API_EXTERNAL_URL:-http://localhost:8000}
GOTRUE_API_HOST=0.0.0.0
GOTRUE_API_PORT=9999
GOTRUE_SITE_URL=${SUPABASE_SITE_URL:-http://localhost:3000}

# --- Email auth ---
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_MAILER_SECURE_EMAIL_CHANGE_ENABLED=true
GOTRUE_MAILER_OTP_EXP=3600

# --- SMTP ---
GOTRUE_SMTP_HOST=${SMTP_HOST}
GOTRUE_SMTP_PORT=${SMTP_PORT:-587}
GOTRUE_SMTP_USER=${SMTP_USER}
GOTRUE_SMTP_PASS=${SMTP_PASS}
GOTRUE_SMTP_ADMIN_EMAIL=${SMTP_ADMIN_EMAIL:-noreply@landomo.cz}
GOTRUE_SMTP_SENDER_NAME=${SMTP_SENDER_NAME:-Landomo}

# --- Rate limiting ---
GOTRUE_RATE_LIMIT_HEADER=X-Forwarded-For
GOTRUE_RATE_LIMIT_EMAIL_SENT=10

# --- External providers ---
# Google OAuth
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=${SUPABASE_API_EXTERNAL_URL:-http://localhost:8000}/auth/v1/callback

# Facebook OAuth
GOTRUE_EXTERNAL_FACEBOOK_ENABLED=true
GOTRUE_EXTERNAL_FACEBOOK_CLIENT_ID=
GOTRUE_EXTERNAL_FACEBOOK_SECRET=
GOTRUE_EXTERNAL_FACEBOOK_REDIRECT_URI=${SUPABASE_API_EXTERNAL_URL:-http://localhost:8000}/auth/v1/callback

# Apple OAuth
GOTRUE_EXTERNAL_APPLE_ENABLED=true
GOTRUE_EXTERNAL_APPLE_CLIENT_ID=
GOTRUE_EXTERNAL_APPLE_SECRET=
GOTRUE_EXTERNAL_APPLE_REDIRECT_URI=${SUPABASE_API_EXTERNAL_URL:-http://localhost:8000}/auth/v1/callback

# Redirect URL allowlist (comma-separated, should include frontend callback URLs)
GOTRUE_URI_ALLOW_LIST=${SUPABASE_REDIRECT_URLS:-}

# --- Misc ---
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED=false
