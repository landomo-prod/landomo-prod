{
  "title": "Data Quality",
  "tags": [
    "landomo",
    "data-quality",
    "monitoring"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "uid": "landomo-data-quality",
  "panels": [
    {
      "id": 1,
      "title": "Data Completeness Score",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL-Czech"
          },
          "rawSql": "SELECT \n  ROUND(100.0 * COUNT(*) FILTER (WHERE \n    title IS NOT NULL AND \n    price IS NOT NULL AND \n    property_type IS NOT NULL AND \n    city IS NOT NULL\n  ) / NULLIF(COUNT(*), 0), 1) as \"Completeness %\"\nFROM properties \nWHERE created_at > NOW() - INTERVAL '24 hours'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          },
          "unit": "percent",
          "decimals": 1
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "title": "Missing Titles",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL-Czech"
          },
          "rawSql": "SELECT COUNT(*) as \"Missing\" FROM properties WHERE title IS NULL OR title = ''",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
