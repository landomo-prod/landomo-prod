{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Scraper Health Overview",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=~\"scrapers-.*\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] }
      }
    },
    {
      "title": "Scrape Run Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(landomo_scraper_scrape_duration_seconds_bucket[1h])) by (le, portal))",
          "legendFormat": "{{portal}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Scrape Runs (success vs failure)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum(increase(landomo_scraper_scrape_runs_total{status=\"success\"}[1h])) by (portal)",
          "legendFormat": "{{portal}} success",
          "refId": "A"
        },
        {
          "expr": "sum(increase(landomo_scraper_scrape_runs_total{status=\"failure\"}[1h])) by (portal)",
          "legendFormat": "{{portal}} failure",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Properties Scraped per Run",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(increase(landomo_scraper_properties_scraped_total{result=\"success\"}[1h])) by (portal)",
          "legendFormat": "{{portal}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Listings Found (last run)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "landomo_scraper_listings_found",
          "legendFormat": "{{portal}} ({{category}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Scraper Errors by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(landomo_scraper_error_count[1h])) by (portal, error_type) * 3600",
          "legendFormat": "{{portal}} - {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Last Run Timestamp",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "landomo_scraper_last_run_timestamp",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "dateTimeFromNow" }
      }
    },
    {
      "title": "Scrape Run Status (from DB)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "pg_scrape_run_stats_count",
          "legendFormat": "{{portal}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Active Scrape Runs",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "expr": "landomo_scraper_scrape_run_active",
          "legendFormat": "{{portal}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [ { "color": "green", "value": 0 }, { "color": "blue", "value": 1 } ] } } }
    },
    {
      "title": "HTTP Request Rate (per scraper)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum(rate(landomo_scraper_http_requests_total[5m])) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "HTTP Request Latency p95 (per scraper)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(landomo_scraper_http_request_duration_seconds_bucket[5m])) by (le, instance))",
          "legendFormat": "{{instance}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["landomo", "scrapers"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "Landomo Scraper Health",
  "uid": "landomo-scraper-health",
  "version": 1
}
