{
  "logger": {
    "level": "info",
    "timestamp": true
  },
  "esclient": {
    "apiVersion": "7.x",
    "hosts": [
      {
        "host": "cz-pelias-elasticsearch",
        "port": 9200
      }
    ]
  },
  "elasticsearch": {
    "settings": {
      "index": {
        "number_of_replicas": "0",
        "number_of_shards": "1",
        "refresh_interval": "1m"
      }
    }
  },
  "api": {
    "services": {
      "pip": {
        "url": "http://cz-pelias-pip:4200"
      },
      "placeholder": {
        "url": "http://cz-pelias-placeholder:3000"
      },
      "libpostal": {
        "url": "http://cz-pelias-libpostal:4400"
      }
    },
    "defaultParameters": {
      "focus.point.lat": 50.0755,
      "focus.point.lon": 14.4378
    }
  },
  "imports": {
    "adminLookup": {
      "enabled": true
    },
    "geonames": {
      "datapath": "/data/geonames",
      "countryCode": "CZ"
    },
    "openstreetmap": {
      "datapath": "/data/openstreetmap",
      "leveldbpath": "/tmp",
      "import": [
        {
          "filename": "czech-republic-latest.osm.pbf"
        }
      ]
    },
    "whosonfirst": {
      "datapath": "/data/whosonfirst",
      "countryCode": "CZ",
      "importPostalcodes": true
    }
  }
}
