# =============================================================================
# landomo-db environment — PostgreSQL + WAL-G
# =============================================================================
# Copy to .env and fill in real values.
# DO NOT commit .env — it contains secrets.
# =============================================================================

# PostgreSQL credentials
DB_USER=landomo
DB_PASSWORD=<db_password>

# =============================================================================
# WAL-G / Hetzner Object Storage
# =============================================================================
# Create a bucket at: https://console.hetzner.cloud → Object Storage
# Create access keys under: Object Storage → Access Keys
#
# Bucket endpoint format: https://<region>.your-objectstorage.com
# Available regions: fsn1 (Falkenstein), nbg1 (Nuremberg), hel1 (Helsinki)
# =============================================================================

WALG_S3_PREFIX=s3://landomo-backups/pg
AWS_ENDPOINT=https://fsn1.your-objectstorage.com
AWS_ACCESS_KEY_ID=<access_key_id>
AWS_SECRET_ACCESS_KEY=<secret_access_key>
AWS_REGION=fsn1
AWS_S3_FORCE_PATH_STYLE=true

# Compression algorithm: zstd (best balance) | lz4 (fastest) | lzma (smallest)
WALG_COMPRESSION_METHOD=zstd

# Delta backup chain: 0 = always full backup; 6 = up to 6 deltas before a new full
WALG_DELTA_MAX_STEPS=6
